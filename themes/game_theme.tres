[resource]
default_font = ExtResource("1_body")
Button/styles/normal = SubResource("SB_normal")
Button/styles/hover = SubResource("SB_hover")
Button/styles/pressed = SubResource("SB_pressed")
Button/styles/focus = SubResource("SB_focus")
Button/styles/disabled = SubResource("SB_disabled")
TitleText/base_type = &"Label"
TitleText/fonts/font = ExtResource("2_title")
